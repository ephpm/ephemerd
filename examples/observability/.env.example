# Copy to .env and adjust if your docker engine isn't Docker Desktop, or
# you want to scrape more than one ephemerd node.
#
# EPHEMERD_TARGET is a comma-separated list of host:port pairs. Whitespace
# around commas is allowed and stripped. Series from each target are
# automatically labelled with `instance="<host:port>"` so Grafana can split
# by node — no extra config needed.
#
# Examples:
#
# Single host (Docker Desktop default — no override needed):
#   EPHEMERD_TARGET=host.docker.internal:9090
#
# Multiple nodes on the same local network:
#   EPHEMERD_TARGET=windows-pc.lan:9090,macmini.lan:9090,linux-box.lan:9090
#
# Podman on Windows (WSL2 backend), single host:
#   set this to the WSL gateway IP that the Podman machine sees:
#     podman machine ssh "ip route | awk '/default/{print \$3}'"
#   Then add :9090. Typical: 172.x.y.1:9090
#
# Podman / Docker on Linux, default bridge gateway routes to host:
#   leave unset, or use host.docker.internal:9090 (extra_hosts maps it).
#
# Remote ephemerd over LAN:
#   <ephemerd-host-ip>:9090

# EPHEMERD_TARGET=host.docker.internal:9090
